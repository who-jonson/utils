{
  "name": "@whoj/utils-monorepo",
  "description": "Collection of common JS / TS helpers/utils by @whoj",
  "version": "2.3.1",
  "private": true,
  "license": "MIT",
  "keywords": [
    "typescript",
    "ts",
    "starter"
  ],
  "scripts": {
    "lint": "eslint \"packages/**/*.{js,ts,tsx,vue,mjs,cjs,mts,cts}\"",
    "lint:fix": "pnpm lint --fix",
    "stub": "pnpm -r run stub",
    "build": "pnpm -r run prepublishOnly",
    "build:types": "rm -rf dist && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --composite false",
    "play": "vite --config ./playground/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "update:doc": "pnpm -r run update:doc",
    "release": "bumpp package.json packages/*/package.json && pnpm -r publish --access public"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/vue": "^8.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/is-glob": "^4.0.4",
    "@types/node": "latest",
    "@types/throttle-debounce": "^5.0.2",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/ui": "^4.0.18",
    "@whoj/eslint-config": "^2.5.0",
    "@whoj/utils": "workspace:^",
    "@whoj/utils-core": "workspace:^",
    "@whoj/utils-php": "workspace:^",
    "@whoj/utils-types": "workspace:^",
    "@whoj/utils-vue": "workspace:^",
    "bumpp": "^10.4.0",
    "c8": "^10.1.3",
    "change-case": "^5.4.4",
    "core-js": "^3.48.0",
    "cross-env": "^10.1.0",
    "dot-prop": "^10.1.0",
    "esbuild": "^0.27.2",
    "esbuild-register": "^3.6.0",
    "eslint": "^9.39.2",
    "eslint-plugin-testing-library": "^7.15.4",
    "esno": "^4.8.0",
    "fast-glob": "^3.3.3",
    "is-glob": "^4.0.3",
    "npm-run-all": "^4.1.5",
    "nuxt": "^4.3.0",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.2",
    "rollup": "^4.57.1",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-node-externals": "^8.1.2",
    "rollup-plugin-postcss": "^4.0.2",
    "scule": "^1.3.0",
    "throttle-debounce": "^5.0.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "unbuild": "^3.6.1",
    "unplugin": "3.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.27",
    "vue-demi": "^0.14.10",
    "vue-router": "^5.0.1",
    "vue-tsc": "^3.2.4"
  },
  "overrides": {
    "vue-demi": "$vue-demi",
    "typescript": "$typescript"
  },
  "workspaces": [
    "./packages/*"
  ],
  "packageManager": "pnpm@10.28.2",
  "author": {
    "name": "Jonson B.",
    "email": "www.jbc.bd@gmail.com",
    "url": "https://who-jonson.github.io"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
