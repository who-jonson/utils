{
  "name": "@whoj/utils-monorepo",
  "description": "Collection of common JS / TS helpers/utils by @whoj",
  "version": "2.4.0",
  "private": true,
  "license": "MIT",
  "keywords": [
    "typescript",
    "ts",
    "starter"
  ],
  "scripts": {
    "lint": "eslint \"packages/**/*.{js,ts,tsx,vue,mjs,cjs,mts,cts}\"",
    "lint:fix": "pnpm lint --fix",
    "stub": "pnpm -r run stub",
    "build": "pnpm -r run prepublishOnly",
    "build:types": "rm -rf dist && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --composite false",
    "play": "vite --config ./playground/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "update:doc": "pnpm -r run update:doc",
    "release": "bumpp package.json packages/*/package.json && pnpm -r publish --access public"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "catalog:",
    "@testing-library/vue": "catalog:",
    "@types/fs-extra": "catalog:",
    "@types/is-glob": "catalog:",
    "@types/node": "catalog:",
    "@types/throttle-debounce": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/ui": "catalog:",
    "@whoj/eslint-config": "catalog:",
    "@whoj/utils": "workspace:^",
    "@whoj/utils-core": "workspace:^",
    "@whoj/utils-php": "workspace:^",
    "@whoj/utils-types": "workspace:^",
    "@whoj/utils-vue": "workspace:^",
    "bumpp": "catalog:",
    "c8": "catalog:",
    "change-case": "catalog:",
    "core-js": "catalog:",
    "cross-env": "catalog:",
    "dot-prop": "catalog:",
    "esbuild": "catalog:",
    "esbuild-register": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-testing-library": "catalog:",
    "esno": "catalog:",
    "fast-glob": "catalog:",
    "is-glob": "catalog:",
    "npm-run-all": "catalog:",
    "nuxt": "catalog:",
    "postcss": "catalog:",
    "rimraf": "catalog:",
    "rollup": "catalog:",
    "rollup-plugin-dts": "catalog:",
    "rollup-plugin-esbuild": "catalog:",
    "rollup-plugin-node-externals": "catalog:",
    "rollup-plugin-postcss": "catalog:",
    "scule": "catalog:",
    "throttle-debounce": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "unbuild": "catalog:",
    "unplugin": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:",
    "vue-tsc": "catalog:"
  },
  "workspaces": [
    "./packages/*"
  ],
  "packageManager": "pnpm@10.33.0",
  "author": {
    "name": "Jonson B.",
    "email": "www.jbc.bd@gmail.com",
    "url": "https://who-jonson.github.io"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
